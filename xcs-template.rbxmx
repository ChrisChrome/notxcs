	<SharedStrings>
		<SharedString md5="aTIjYIeEFqyQ2bhuh8rtLg==">Q1NHUEhTCAAAAAIAKLUv/WDEDW0mANQiEgAAACsBAAAOAgAAI0IACgQAAIQEDgAA7FG4veF6
